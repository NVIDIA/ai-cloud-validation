# Terraform state files
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Runtime signal: a leaked GPU capacity-preflight probe pending reclaim
# (written by setup, consumed by teardown's preservation path).
retained-probes-*.marker

# Runtime ledger: exact identities of this run's PVC-backed Persistent Disks,
# captured while the cluster is live so teardown reclaims only ledger-proven disks.
owned-pds-*.ledger

# Terraform cache
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# User-specific variables (may contain sensitive data)
terraform.tfvars
*.auto.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Plan files
*.tfplan
tfplan
