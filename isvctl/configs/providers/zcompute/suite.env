# zCompute ISV-NCP Validation Suite — environment variables
#
# Fill in the values for your environment, then source before running:
#   source isvctl/configs/providers/zcompute/suite.env
#   uv run isvctl test run -f isvctl/configs/providers/zcompute/config/network.yaml
#
# ─────────────────────────────────────────────────────────────────────────────
# zCompute cluster
# ─────────────────────────────────────────────────────────────────────────────

export ZCOMPUTE_BASE_URL=https://172.29.0.20

# ─────────────────────────────────────────────────────────────────────────────
# AWS-compatible API endpoints
# ─────────────────────────────────────────────────────────────────────────────

export AWS_ENDPOINT_URL_EC2=${ZCOMPUTE_BASE_URL}/api/v2/aws/ec2/
export AWS_ENDPOINT_URL_IAM=${ZCOMPUTE_BASE_URL}/api/v2/aws/iam/
export AWS_ENDPOINT_URL_STS=${ZCOMPUTE_BASE_URL}/api/v2/aws/sts/

export AWS_REGION=symphony
export AWS_ACCESS_KEY_ID=
export AWS_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# symp CLI credentials (needed for control-plane disable_access_key fallback
# and isolation_test VPC peering describe fallback)
# ─────────────────────────────────────────────────────────────────────────────

export SYMP_URL=http://172.29.0.20
export SYMP_USER=
export SYMP_DOMAIN=
export SYMP_PROJECT=
export SYMP_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# VM-dependent network tests (dhcp_ip, stable_ip, floating_ip)
# Find available images:  aws ec2 describe-images (with endpoint set above)
# ─────────────────────────────────────────────────────────────────────────────

export ZCOMPUTE_TEST_AMI_ID=
export ZCOMPUTE_TEST_INSTANCE_TYPE=z2.3large

# ─────────────────────────────────────────────────────────────────────────────
# Kubernetes / EKS-D suite
# ─────────────────────────────────────────────────────────────────────────────

export KUBECONFIG=~/.kube/config

# ─────────────────────────────────────────────────────────────────────────────
# NIM inference tests (VM and K8s suites)
# ─────────────────────────────────────────────────────────────────────────────

export NGC_API_KEY=
